{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semantics-as-code.org/schemas/metric.schema.json",
  "title": "Metric",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "name", "display_name", "description", "formula", "grain", "owner", "version"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "metric" },
    "name": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "formula": { "type": "string", "minLength": 1 },
    "grain": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "steward": { "type": "string" },
    "domain": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "deprecated", "retired"] },
    "classification": { "enum": ["Public", "Internal", "Confidential", "Restricted"] },
    "dimensions": { "type": "array", "items": { "type": "string" } },
    "filters": { "type": "array", "items": { "type": "string" } },
    "source": { "type": "string" },
    "quality": { "type": "array", "items": { "type": "string" } },
    "synonyms": { "type": "array", "items": { "type": "string" } },
    "glossary_terms": { "type": "array", "items": { "type": "string" } },
    "ai_context": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "extensions": { "type": "object" }
  }
}
