{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semantics-as-code.org/schemas/semantic-package.schema.json",
  "title": "Semantic Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "name", "display_name", "description", "owner", "version", "spec_version"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "semantic_package" },
    "name": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "spec_version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "deprecated", "retired"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "lint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rules": {
          "type": "object",
          "additionalProperties": {
            "enum": ["off", "warning", "error"]
          }
        }
      }
    },
    "generators": {
      "type": "object"
    },
    "extensions": { "type": "object" }
  },
  "examples": [
    {
      "id": "supply-chain",
      "kind": "semantic_package",
      "name": "Supply Chain",
      "display_name": "Supply Chain",
      "description": "Supply chain starter semantic package.",
      "owner": "Data Governance",
      "version": "0.2.0",
      "spec_version": "0.2.0"
    }
  ]
}
