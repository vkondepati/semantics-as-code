{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semantics-as-code.org/schemas/quality-expectation.schema.json",
  "title": "Quality Expectation",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "name", "display_name", "description", "target", "expectation", "severity", "owner", "version"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "quality_expectation" },
    "name": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "expectation": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["info", "warning", "error", "critical"] },
    "owner": { "type": "string", "minLength": 1 },
    "steward": { "type": "string" },
    "domain": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "deprecated", "retired"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source": { "type": "string" },
    "extensions": { "type": "object" }
  }
}
