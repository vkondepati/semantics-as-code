---
import "../styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import BackToTop from "@components/BackToTop.astro";
import { siteUrl } from "@data/site";
import { withBase } from "@lib/paths";

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
const canonical = new URL(`semantics-as-code${path}`, "https://vkondepati.github.io/").toString();
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Semantics as Code</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={withBase("assets/favicon.svg")} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Semantics as Code`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}assets/social-preview.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Semantics as Code`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}assets/social-preview.svg`} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareSourceCode",
      name: "Semantics as Code",
      codeRepository: "https://github.com/vkondepati/semantics-as-code",
      programmingLanguage: ["Python", "YAML", "TypeScript"],
      description
    })}></script>
  </head>
  <body>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
    <BackToTop />
    <script>
      const storedTheme = localStorage.getItem("sac-theme");
      if (storedTheme) document.documentElement.dataset.theme = storedTheme;
      document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
        button.addEventListener("click", () => {
          const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          localStorage.setItem("sac-theme", next);
        });
      });
      document.querySelectorAll("[data-copy]").forEach((button) => {
        button.addEventListener("click", async () => {
          const target = document.querySelector(button.getAttribute("data-copy"));
          if (!target) return;
          await navigator.clipboard.writeText(target.textContent || "");
          button.textContent = "Copied";
          setTimeout(() => (button.textContent = "Copy"), 1200);
        });
      });
      document.querySelectorAll("[data-tab-list]").forEach((list) => {
        const tabs = Array.from(list.querySelectorAll("[role='tab']"));
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const panelId = tab.getAttribute("aria-controls");
            tabs.forEach((item) => item.setAttribute("aria-selected", String(item === tab)));
            document.querySelectorAll(`[data-tab-panel='${list.id}']`).forEach((panel) => {
              panel.hidden = panel.id !== panelId;
            });
          });
        });
      });
      const mobile = document.querySelector("[data-mobile-toggle]");
      const nav = document.querySelector("[data-nav]");
      mobile?.addEventListener("click", () => nav?.toggleAttribute("data-open"));
    </script>
  </body>
</html>
