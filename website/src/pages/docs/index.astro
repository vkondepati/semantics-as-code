---
import BaseLayout from "@layouts/BaseLayout.astro";
import { docs } from "@lib/repo";
import { withBase } from "@lib/paths";
const pages = docs();
---
<BaseLayout title="Documentation" description="Documentation hub rendering existing Semantics as Code Markdown documentation." path="/docs/">
  <section class="section"><div class="shell">
    <p class="kicker">Documentation</p>
    <h1>Documentation hub</h1>
    <p class="lead">Existing Markdown documentation from the repository is rendered into a searchable site section.</p>
    <label class="search-label">Search docs <input type="search" placeholder="Search documentation" data-doc-search /></label>
    <div class="grid" data-doc-list>
      {pages.map((page) => <article class="card" data-doc-card data-title={page.title.toLowerCase()}><h3>{page.title}</h3><p><code>{page.file}</code></p><a href={withBase(`/docs/${page.slug}/`)}>Open</a></article>)}
    </div>
  </div></section>
  <script>
    const input = document.querySelector("[data-doc-search]");
    input?.addEventListener("input", () => {
      const query = input.value.toLowerCase();
      document.querySelectorAll("[data-doc-card]").forEach((card) => {
        card.hidden = !card.getAttribute("data-title").includes(query);
      });
    });
  </script>
</BaseLayout>
<style>
  .search-label { display: grid; gap: 8px; max-width: 420px; margin: 26px 0; font-weight: 800; }
  input { min-height: 44px; padding: 10px 12px; border: 1px solid var(--line); border-radius: 6px; background: var(--white); color: var(--ink); }
</style>
